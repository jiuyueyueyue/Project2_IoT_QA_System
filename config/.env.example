# ============================================================
# IoT 智能家居多标签问答系统 — 环境变量模板
# 复制为 .env 并修改对应值（.env 不会被 git 追踪）
# ============================================================

# --- 基础路径 ---
PROJECT_ROOT=.
DATA_DIR=./data
OUTPUT_DIR=./output
MODEL_DIR=./output/models
LOG_DIR=./output/logs

# --- 数据文件 ---
RAW_DATA_PATH=./data/labeled_data.csv
CLEANED_DATA_PATH=./data/cleaned_data.csv

# --- 模型文件名前缀 ---
MODEL_NAME_PREFIX=best_model

# --- TF-IDF ---
TFIDF_MAX_FEATURES=5000
TFIDF_NGRAM_MIN=1
TFIDF_NGRAM_MAX=2
TFIDF_ANALYZER=char

# --- 训练参数 ---
TRAIN_TEST_SIZE=0.2
TRAIN_VAL_SIZE=0.1
TRAIN_RANDOM_STATE=42

# --- 推理默认值 ---
INFERENCE_THRESHOLD=0.3
INFERENCE_MAX_LABELS=10
INFERENCE_BATCH_SIZE=32

# --- Flask 服务 ---
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# --- 日志 ---
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s:%(lineno)d - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
